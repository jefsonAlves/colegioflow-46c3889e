{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://efuaviwbpknybbuxpegh.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "colegio-em-movimento-mcp",
      "version": "0.1.0",
      "title": "Colégio em Movimento"
    },
    "tools": [
      {
        "name": "echo",
        "title": "Echo",
        "description": "Echo the input text back to the caller. Useful to verify connectivity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "description": "Text to echo back."
            }
          },
          "required": [
            "text"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_schools",
        "title": "List my schools",
        "description": "List the schools the signed-in user belongs to (with role and approval status).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_classes",
        "title": "List classes",
        "description": "List classes in a school the signed-in user has access to.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "school_id": {
              "type": "string",
              "format": "uuid",
              "description": "School UUID (from list_my_schools)."
            }
          },
          "required": [
            "school_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_students",
        "title": "List students",
        "description": "List students in a school, optionally filtered by class. Returns only fields visible to the signed-in user via RLS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "school_id": {
              "type": "string",
              "format": "uuid",
              "description": "School UUID."
            },
            "class_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional class UUID to filter by."
            }
          },
          "required": [
            "school_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "search_students",
        "title": "Search students",
        "description": "Search students by (partial) name with stable keyset pagination, sorting, and optional filters by school, class, or teacher. Returns only rows visible to the signed-in user via RLS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "school_id": {
              "type": "string",
              "format": "uuid",
              "description": "School UUID to search within."
            },
            "query": {
              "type": "string",
              "maxLength": 120,
              "description": "Case-insensitive substring to match against the student name."
            },
            "class_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional class UUID to restrict the search."
            },
            "teacher_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional teacher UUID. If provided, restricts to classes that teacher leads."
            },
            "sort": {
              "type": "string",
              "enum": [
                "name_asc",
                "name_desc",
                "created_desc",
                "created_asc"
              ],
              "default": "name_asc",
              "description": "Sort order for results."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Page size (max 100)."
            },
            "cursor": {
              "type": "string",
              "description": "Opaque cursor returned as `nextCursor` from a previous call. Preferred over `offset` for stable pagination."
            },
            "offset": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Deprecated. Use `cursor` for stable pagination; kept for backward compatibility."
            }
          },
          "required": [
            "school_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_announcements",
        "title": "List announcements",
        "description": "List the most recent announcements for a school (up to 100).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "school_id": {
              "type": "string",
              "format": "uuid",
              "description": "School UUID."
            }
          },
          "required": [
            "school_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_announcement",
        "title": "Create announcement",
        "description": "Create a school announcement as the signed-in user. Requires teacher/admin role via RLS.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "school_id": {
              "type": "string",
              "format": "uuid"
            },
            "class_id": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional class UUID to target."
            },
            "audience": {
              "type": "string",
              "enum": [
                "parents",
                "teachers",
                "all"
              ],
              "default": "all"
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "body": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "school_id",
            "title",
            "body"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
