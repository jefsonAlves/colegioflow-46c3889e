{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null && root.child('users').child(auth.uid).child('globalRole').val() == 'master'",

    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('globalRole').val() == 'master')"
      }
    },

    "schools": {
      ".read": "auth != null",
      "$sid": {
        ".write": "auth != null"
      }
    },

    "school_memberships": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "classes": {
